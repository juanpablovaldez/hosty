# Database
# For local development (no Docker):
DATABASE_URL="postgresql://hosty:hosty_dev@localhost:5432/hosty_dev"
# For Docker (docker-compose.yml at repo root sets this automatically):
# DATABASE_URL="postgresql://hosty:hosty_dev@postgres:5432/hosty_dev?schema=public"

# App
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"

# AWS Cognito (required for JWT validation in production)
AWS_REGION="us-east-1"
COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
