# Local Terraform state
*.tfstate
*.tfstate.backup

# Terraform working directory
.terraform/

# Crash log files
crash.log

# Sensitive tfvars (keep config/*.tfvars tracked)
*.tfvars
!config/*.tfvars

# Override files (local-only overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
