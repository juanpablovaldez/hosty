{
  "name": "hosty",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "npm run lint --workspace=backend",
      "npm run format --workspace=backend"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "npm run lint --workspace=frontend"
    ]
  }
}
